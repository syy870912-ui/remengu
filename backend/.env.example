# 股析AI 环境变量示例
# 复制此文件为 .env 并填写实际值

# --- 必填 ---
# JWT 签名密钥（生产环境必须修改，至少32字符）
SECRET_KEY=your-super-secret-jwt-key-at-least-32-chars

# --- 可选（有默认值）---
# 后端监听端口（Railway 自动注入 PORT 变量）
PORT=8000

# CORS 允许的来源域名（逗号分隔）
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# 数据库 URL（默认 SQLite，可改为 PostgreSQL）
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# 定时任务时间（工作日 15:35 执行）
SCHEDULE_HOUR=15
SCHEDULE_MINUTE=35

# 采集配置
MAX_STOCKS=200
SCRAPE_TIMEOUT=30
CONCURRENT_LIMIT=10
ARTICLE_DELAY=0.1
